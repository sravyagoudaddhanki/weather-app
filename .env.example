# ============================================================
# WEATHER APP - Environment Variables
# ============================================================
# 1. Copy this file and rename it to: .env
# 2. Replace the placeholder below with your real API key
# 3. Get a FREE API key at: https://openweathermap.org/api
#    (Sign up → API keys → Copy your key)
# ============================================================

VITE_OPENWEATHER_API_KEY=your_openweathermap_api_key_here
